{
  "$schema": "https://json.schemastore.org/tsconfig",
  "_comment": "Fully-descriptive TypeScript 6 base config. Every non-deprecated, environment-agnostic compilerOption is listed explicitly, even when the value equals the TS 6 default, so consumers can read the file and know exactly what is being enforced.",
  "compilerOptions": {
    "strict": true,
    "alwaysStrict": true,
    "noImplicitAny": true,
    "noImplicitThis": true,
    "strictNullChecks": true,
    "strictFunctionTypes": true,
    "strictBindCallApply": true,
    "strictPropertyInitialization": true,
    "strictBuiltinIteratorReturn": true,
    "useUnknownInCatchVariables": true,
    "exactOptionalPropertyTypes": true,
    "noImplicitOverride": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "noPropertyAccessFromIndexSignature": true,
    "noUncheckedIndexedAccess": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "allowUnreachableCode": false,
    "allowUnusedLabels": false,

    "module": "nodenext",
    "moduleResolution": "nodenext",
    "moduleDetection": "force",
    "resolveJsonModule": true,
    "resolvePackageJsonExports": true,
    "resolvePackageJsonImports": true,
    "allowArbitraryExtensions": false,
    "allowImportingTsExtensions": false,
    "allowUmdGlobalAccess": false,
    "noResolve": false,
    "noUncheckedSideEffectImports": true,
    "rewriteRelativeImportExtensions": false,
    "customConditions": [],
    "moduleSuffixes": [],
    "paths": {},
    "rootDirs": [],
    "typeRoots": ["./node_modules/@types"],
    "types": [],

    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "inlineSourceMap": false,
    "inlineSources": false,
    "emitBOM": false,
    "emitDeclarationOnly": false,
    "importHelpers": false,
    "newLine": "lf",
    "noEmit": false,
    "noEmitHelpers": false,
    "noEmitOnError": true,
    "preserveConstEnums": true,
    "removeComments": false,
    "stripInternal": true,

    "allowJs": false,
    "checkJs": false,
    "maxNodeModuleJsDepth": 0,

    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true,
    "isolatedDeclarations": false,
    "verbatimModuleSyntax": true,
    "erasableSyntaxOnly": false,
    "preserveSymlinks": false,

    "target": "es2025",
    "lib": ["es2025"],
    "useDefineForClassFields": true,
    "experimentalDecorators": false,
    "emitDecoratorMetadata": false,
    "noLib": false,
    "libReplacement": false,

    "skipLibCheck": true,
    "skipDefaultLibCheck": false,

    "pretty": true,
    "noErrorTruncation": true,

    "composite": false,
    "incremental": false,
    "disableReferencedProjectLoad": false,
    "disableSolutionSearching": false,
    "disableSourceOfProjectReferenceRedirect": false,

    "disableSizeLimit": false,
    "plugins": []
  }
}
